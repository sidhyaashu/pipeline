# =============================================================================
# DATABASE CONFIG (TEST - HOST COMPATIBLE)
# =============================================================================
DATABASE_URL=postgresql+psycopg2://test_user:test_password@127.0.0.1:5432/test_db

# =============================================================================
# INTERNAL FILE PATHS (HOST COMPATIBLE)
# =============================================================================
SQL_DIR=./sql
SCHEMA_DIR=./schemas
DATA_DIR=./tests/data

# =============================================================================
# ACCORD API CONFIG
# =============================================================================
ACCORD_API_TOKEN=Gp4r5wfgNYi72c0EdpWSf21oLLVjlwzr
API_DATE=10052024

# =============================================================================
# API PROCESSING CONFIG
# =============================================================================
ETL_BATCH_SIZE=5000

# =============================================================================
# API INGESTION HARDENING
# =============================================================================
ENABLE_IDEMPOTENCY=false
ENABLE_REJECTED_RETRY=true
MAX_REJECTED_ROW_RETRY=5
ALLOW_MASS_DELETE=false
MAX_FEED_CONSECUTIVE_FAILURES=3

# =============================================================================
# API CLIENT RETRY CONFIG
# =============================================================================
API_MAX_RETRIES=3
API_RETRY_BACKOFF_1=2
API_RETRY_BACKOFF_2=5
API_RETRY_BACKOFF_3=10
API_TIMEOUT_SECONDS=60

# =============================================================================
# RAW PAYLOAD CLEANUP
# =============================================================================
RAW_PAYLOAD_RETENTION_DAYS=14
ENABLE_RAW_PAYLOAD_CLEANUP=true

# =============================================================================
# SCHEDULER CONFIG (TEST)
# =============================================================================
TIMEZONE=Asia/Kolkata
COMPANY_MASTER_HOURS=10,13,16,22
COMPANY_MASTER_MINUTE=0
RESULTS_START_HOUR=9
RESULTS_END_HOUR=23
RESULTS_MINUTE=5
RESULTS_FINAL_HOUR=23
RESULTS_FINAL_MINUTE=30
EOD_HOUR=22
EOD_MINUTE=45
EOD_RETRY_HOUR=23
EOD_RETRY_MINUTE=30

# =============================================================================
# ALERTING & LOGGING
# =============================================================================
ENABLE_ALERTS=false
LOG_LEVEL=DEBUG
LOG_RAW_PAYLOAD=true

# =============================================================================
# DATABASE CONFIG (AZURE POSTGRESQL)
# =============================================================================
DATABASE_URL=postgresql+psycopg2://InvestKode:Xpolog%4000%26@finglobalai-data-dum.postgres.database.azure.com:5432/financial_db?sslmode=require

# =============================================================================
# INTERNAL FILE PATHS
# =============================================================================
SQL_DIR=/app/sql
SCHEMA_DIR=/app/schemas

# =============================================================================
# ACCORD API CONFIG
# =============================================================================
ACCORD_API_TOKEN=Gp4r5wfgNYi72c0EdpWSf21oLLVjlwzr

# Optional manual override date for testing (Format: DDMMYYYY). 
# Leave blank for today's date.
API_DATE=

# =============================================================================
# API PROCESSING CONFIG
# =============================================================================
# Batch size for inserting API chunk payloads into the database
ETL_BATCH_SIZE=10000

# =============================================================================
# API INGESTION HARDENING
# =============================================================================
ENABLE_IDEMPOTENCY=false
ENABLE_REJECTED_RETRY=true
MAX_REJECTED_ROW_RETRY=5
ALLOW_MASS_DELETE=false
MAX_FEED_CONSECUTIVE_FAILURES=3

# =============================================================================
# API CLIENT RETRY CONFIG
# =============================================================================
API_MAX_RETRIES=3
API_RETRY_BACKOFF_1=2
API_RETRY_BACKOFF_2=5
API_RETRY_BACKOFF_3=10
API_TIMEOUT_SECONDS=60

# =============================================================================
# RAW PAYLOAD CLEANUP
# =============================================================================
RAW_PAYLOAD_RETENTION_DAYS=14
ENABLE_RAW_PAYLOAD_CLEANUP=true

# =============================================================================
# SCHEDULER CONFIG
# =============================================================================
TIMEZONE=Asia/Kolkata

# Company Master intraday times
COMPANY_MASTER_HOURS=10,13,16,22
COMPANY_MASTER_MINUTE=35

# Results hourly times
RESULTS_START_HOUR=9
RESULTS_END_HOUR=23
RESULTS_MINUTE=5
RESULTS_FINAL_HOUR=23
RESULTS_FINAL_MINUTE=30

# EOD feeds
EOD_HOUR=22
EOD_MINUTE=45

# EOD retry
EOD_RETRY_HOUR=23
EOD_RETRY_MINUTE=30

# =============================================================================
# ALERTING & LOGGING
# =============================================================================
ENABLE_ALERTS=true
LOG_LEVEL=INFO
LOG_RAW_PAYLOAD=false
